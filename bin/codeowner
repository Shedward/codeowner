#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "Usage: codeowner <path>" >&2
  exit 1
}

# Find the git repo root for a given path.
# Walks up from the path to find an existing directory (the file itself may not exist).
find_repo_root() {
  local path="$1"
  local dir
  [[ -d "${path}" ]] && dir="${path}" || dir="$(dirname "${path}")"
  git -C "${dir}" rev-parse --show-toplevel 2>/dev/null
}

normalize_path() {
  local path="${1#./}"
  path="${path%/}"
  local repo_root="$2"

  # Resolve to repo-root-relative path so the script works from any directory.
  local abs_path
  if [[ "${path}" == /* ]]; then
    abs_path="${path}"
  else
    abs_path="${PWD}/${path}"
  fi

  if [[ -n "${repo_root}" && "${abs_path}" == "${repo_root}/"* ]]; then
    echo "${abs_path#"${repo_root}/"}"
  else
    echo "${path}"
  fi
}

find_owner() {
  local filepath="$1"
  local codeowners_file="$2"
  local matched=""

  while IFS= read -r line; do
    [[ "${line}" =~ ^# || -z "${line}" ]] && continue

    local pattern="${line%% *}"
    if [[ "${filepath}" =~ ^${pattern}$ || "${filepath}/" =~ ^${pattern}$ || "${filepath}" =~ ^${pattern}/ ]]; then
      matched="${line}"
    fi
  done < "${codeowners_file}"

  echo "${matched}"
}

format_result() {
  local line="$1"
  local team=""
  local func=""

  [[ "${line}" =~ @hhru/([^[:space:]]+) ]] && team="${BASH_REMATCH[1]}"
  [[ "${line}" =~ hh-func:[[:space:]]*([^[:space:]]+) ]] && func="${BASH_REMATCH[1]%,}"

  if [[ -n "${func}" ]]; then
    echo "${team} (${func})"
  else
    echo "${team}"
  fi
}

main() {
  if [[ $# -ne 1 ]]; then
    usage
  fi

  # Resolve the argument to an absolute path for repo-root detection.
  local raw="${1#./}"; raw="${raw%/}"
  local abs_path
  if [[ "${raw}" == /* ]]; then
    abs_path="${raw}"
  else
    abs_path="${PWD}/${raw}"
  fi

  local repo_root
  repo_root="$(find_repo_root "${abs_path}")" || true

  if [[ -z "${repo_root}" && -z "${CODEOWNERS_FILE:-}" ]]; then
    echo "Error: '${raw}' is not inside a git repository" >&2
    exit 1
  fi

  local codeowners_file="${CODEOWNERS_FILE:-${repo_root}/CODEOWNERS_HH}"

  local filepath
  filepath="$(normalize_path "${raw}" "${repo_root}")"

  local matched_line
  matched_line="$(find_owner "${filepath}" "${codeowners_file}")"

  if [[ -z "${matched_line}" ]]; then
    echo "No owner found for: ${filepath}" >&2
    exit 1
  fi

  format_result "${matched_line}"
}

main "$@"
