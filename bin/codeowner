#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "Usage: codeowner <path>" >&2
  exit 1
}

find_repo_root() {
  local dir="$1"
  until [[ -d "${dir}" || "${dir}" == "/" ]]; do
    dir="$(dirname "${dir}")"
  done
  git -C "${dir}" rev-parse --show-toplevel 2>/dev/null
}

find_owner() {
  local filepath="$1"
  local codeowners_file="$2"
  local matched=""

  while IFS= read -r line; do
    [[ "${line}" =~ ^# || -z "${line}" ]] && continue

    local pattern="${line%% *}"
    if [[ "${filepath}" =~ ^${pattern}$ || "${filepath}/" =~ ^${pattern}$ || "${filepath}" =~ ^${pattern}/ ]]; then
      matched="${line}"
    fi
  done < "${codeowners_file}"

  echo "${matched}"
}

format_result() {
  local line="$1"
  local team=""
  local func=""

  [[ "${line}" =~ @hhru/([^[:space:]]+) ]] && team="${BASH_REMATCH[1]}"
  [[ "${line}" =~ hh-func:[[:space:]]*([^[:space:]]+) ]] && func="${BASH_REMATCH[1]%,}"

  if [[ -n "${func}" ]]; then
    echo "${team} (${func})"
  else
    echo "${team}"
  fi
}

main() {
  if [[ $# -ne 1 ]]; then
    usage
  fi

  local raw="${1#./}"; raw="${raw%/}"
  local abs_path
  [[ "${raw}" == /* ]] && abs_path="${raw}" || abs_path="${PWD}/${raw}"

  local repo_root
  repo_root="$(find_repo_root "${abs_path}")" || true

  if [[ -z "${repo_root}" && -z "${CODEOWNERS_FILE:-}" ]]; then
    echo "Error: '${raw}' is not inside a git repository" >&2
    exit 1
  fi

  local codeowners_file="${CODEOWNERS_FILE:-${repo_root}/CODEOWNERS_HH}"
  local filepath="${abs_path#"${repo_root}/"}"

  local matched_line
  matched_line="$(find_owner "${filepath}" "${codeowners_file}")"

  if [[ -z "${matched_line}" ]]; then
    echo "No owner found for: ${filepath}" >&2
    exit 1
  fi

  format_result "${matched_line}"
}

main "$@"
